{
  "name": "starkeen/yandex-search-api",
  "description": "Library for using Yandex Search API",
  "keywords": ["yandex", "api", "search", "client", "HTTP client"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrei Panisko",
      "email": "starkeen@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^8.1",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/log": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "YandexSearchAPI\\": "src/"
    }
  },
  "require-dev": {
    "nyholm/psr7": "^1.8",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.5 || ^11.5",
    "squizlabs/php_codesniffer": "^3.8"
  },
  "autoload-dev": {
    "psr-4": {
      "YandexSearchAPI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests",
    "test-coverage": "phpunit --coverage-html=coverage tests"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "composer-exit-on-patch": true
  }
}
